+	 * Strictly opt-in via env var and restricted to ov02e10, so
+	 * other distros and other sensors are unaffected.
+	 */
+	if (sensor->model() == "ov02e10") {
+		const char *forceRot = std::getenv("LIBCAMERA_FORCE_OV02E10_ROTATION");
